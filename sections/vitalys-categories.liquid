<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} vitalys-categories color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings %}"
  data-section-id="{{ section.id }}"
>
  {%- if section.settings.heading != blank -%}
    <div class="vitalys-categories__header">
      <h2 class="vitalys-categories__heading">{{ section.settings.heading | escape }}</h2>
    </div>
  {%- endif -%}

  <div class="vitalys-categories__scroll">
    {%- for block in section.blocks -%}
      <a
        class="vitalys-categories__card"
        href="{{ block.settings.link | default: '#' }}"
        {{ block.shopify_attributes }}
      >
        <div class="vitalys-categories__card-media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 320
              | image_tag:
                loading: 'lazy',
                class: 'vitalys-categories__card-img',
                alt: block.settings.title | escape
            }}
          {%- else -%}
            <div class="vitalys-categories__card-placeholder" aria-hidden="true"></div>
          {%- endif -%}
          <div class="vitalys-categories__card-gradient" aria-hidden="true"></div>
          {%- if block.settings.title != blank -%}
            <span class="vitalys-categories__card-label">{{ block.settings.title | escape }}</span>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "VITALYS Categorías",
  "tag": "section",
  "class": "section-wrapper",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "¿Cuál es tu objetivo?"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen lifestyle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de categoría",
          "default": "Sueño y descanso"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace a colección"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VITALYS Categorías",
      "settings": {
        "heading": "¿Cuál es tu objetivo?",
        "color_scheme": "scheme-1"
      },
      "blocks": [
        { "type": "category_card", "settings": { "title": "Sueño y descanso" } },
        { "type": "category_card", "settings": { "title": "Energía y foco" } },
        { "type": "category_card", "settings": { "title": "Rendimiento" } },
        { "type": "category_card", "settings": { "title": "Salud digestiva" } },
        { "type": "category_card", "settings": { "title": "Estrés" } },
        { "type": "category_card", "settings": { "title": "Piel y cabello" } }
      ]
    }
  ]
}
{% endschema %}
