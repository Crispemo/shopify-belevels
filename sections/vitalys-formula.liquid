<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} vitalys-formula color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings %}"
  data-section-id="{{ section.id }}"
>
  <div class="vitalys-formula__inner">
    <div class="vitalys-formula__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            class: 'vitalys-formula__image',
            alt: section.settings.heading | escape
        }}
      {%- else -%}
        <div class="vitalys-formula__image-placeholder" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2v17.5c0 1.4-1.1 2.5-2.5 2.5h0c-1.4 0-2.5-1.1-2.5-2.5V2"/><path d="M8.5 2h7"/><path d="M14.5 16h-5"/></svg>
        </div>
      {%- endif -%}
    </div>

    <div class="vitalys-formula__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="vitalys-formula__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <div class="vitalys-formula__highlight">
        {%- if section.settings.ingredient_name != blank -%}
          <p class="vitalys-formula__ingredient-name">{{ section.settings.ingredient_name | escape }}</p>
        {%- endif -%}
        {%- if section.settings.ingredient_dose != blank -%}
          <p class="vitalys-formula__ingredient-dose">{{ section.settings.ingredient_dose | escape }}</p>
        {%- endif -%}
        {%- if section.settings.ingredient_description != blank -%}
          <p class="vitalys-formula__ingredient-body">{{ section.settings.ingredient_description | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="vitalys-formula__cta"
        >
          {{ section.settings.cta_label | escape }} &rarr;
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VITALYS Fórmula",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (ingrediente o packaging)"
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titular",
      "default": "Cada miligramo tiene un motivo."
    },
    {
      "type": "text",
      "id": "ingredient_name",
      "label": "Nombre del ingrediente",
      "default": "Magnesio bisglicinato · 300 mg por dosis"
    },
    {
      "type": "text",
      "id": "ingredient_dose",
      "label": "Dato clave",
      "default": "Absorción 4× superior al óxido de magnesio"
    },
    {
      "type": "textarea",
      "id": "ingredient_description",
      "label": "Explicación breve",
      "default": "La forma química importa. El bisglicinato atraviesa la barrera intestinal de forma eficiente. El óxido no."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del enlace",
      "default": "Ver todos los ingredientes"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Destino del enlace"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "VITALYS Fórmula",
      "settings": {
        "heading": "Cada miligramo tiene un motivo.",
        "ingredient_name": "Magnesio bisglicinato · 300 mg por dosis",
        "ingredient_dose": "Absorción 4× superior al óxido de magnesio",
        "ingredient_description": "La forma química importa. El bisglicinato atraviesa la barrera intestinal de forma eficiente. El óxido no.",
        "cta_label": "Ver todos los ingredientes",
        "color_scheme": "scheme-5"
      }
    }
  ]
}
{% endschema %}
